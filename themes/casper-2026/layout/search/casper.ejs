<div class="cs-modal" id="cs-search" role="dialog" aria-modal="true" aria-label="搜尋文章">
  <div class="cs-box" data-cs-stop>
    <div class="cs-top">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
      <input id="cs-input" type="search" autocomplete="off" placeholder="搜尋文章標題、分類或標籤…" aria-label="搜尋">
      <kbd>esc</kbd>
      <button type="button" data-cs-close class="iconbtn" style="width:30px;height:30px;border:0" aria-label="關閉">✕</button>
    </div>
    <div class="cs-status" id="cs-status">載入中…</div>
    <ul class="cs-results" id="cs-results"></ul>
    <div class="cs-foot">
      <span>↑↓ 切換 · ↵ 開啟 · esc 關閉</span>
      <span>共 <span id="cs-total">0</span> 篇</span>
    </div>
  </div>
</div>

<script>
(function () {
  var CONTENT_URL = '<%- url_for("/content.json") %>';
  var modal = document.getElementById('cs-search');
  var input = document.getElementById('cs-input');
  var resultsEl = document.getElementById('cs-results');
  var statusEl = document.getElementById('cs-status');
  var totalEl = document.getElementById('cs-total');
  var corpus = null, activeIdx = -1, items = [];

  function esc(s){ return (s||'').replace(/[&<>"']/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];}); }
  function hl(text,q){ if(!q) return esc(text); var t=esc(text); try{ var re=new RegExp('('+q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')+')','ig'); return t.replace(re,'<mark>$1</mark>'); }catch(e){return t;} }

  function open(){ modal.classList.add('open'); document.documentElement.style.overflow='hidden'; setTimeout(function(){input.focus();},30); if(!corpus) load(); }
  function close(){ modal.classList.remove('open'); document.documentElement.style.overflow=''; input.value=''; render([], ''); }
  function toggle(){ modal.classList.contains('open') ? close() : open(); }

  function load(){
    statusEl.textContent='載入中…';
    fetch(CONTENT_URL).then(function(r){return r.json();}).then(function(data){
      var posts = data.posts || data || [];
      corpus = posts.map(function(p){
        var tags = (p.tags||[]).map(function(t){return t.name||t;}).join(' ');
        var cats = (p.categories||[]).map(function(c){return c.name||c;}).join(' ');
        var u = p.permalink || p.path || '';
        if (u && !/^https?:\/\//.test(u) && u.charAt(0) !== '/') u = '/' + u;
        return { title:p.title||'（無標題）', url:u, date:p.date||'', cats:cats, hay:((p.title||'')+' '+cats+' '+tags).toLowerCase() };
      });
      statusEl.textContent='輸入關鍵字開始搜尋。共 '+corpus.length+' 篇文章。';
      totalEl.textContent=corpus.length;
    }).catch(function(){ statusEl.textContent='無法載入索引，請稍後再試。'; });
  }

  function search(q){ if(!corpus) return []; var query=q.trim().toLowerCase(); if(!query) return []; var m=[]; for(var i=0;i<corpus.length&&m.length<50;i++){ if(corpus[i].hay.indexOf(query)!==-1) m.push(corpus[i]); } return m; }

  function render(matches,q){
    items=matches; activeIdx=matches.length?0:-1;
    if(!q){ resultsEl.innerHTML=''; if(corpus) statusEl.textContent='輸入關鍵字開始搜尋。共 '+corpus.length+' 篇文章。'; totalEl.textContent=corpus?corpus.length:0; return; }
    if(!matches.length){ resultsEl.innerHTML=''; statusEl.textContent='找不到「'+q+'」相關文章'; totalEl.textContent=0; return; }
    statusEl.textContent='「'+q+'」的搜尋結果'; totalEl.textContent=matches.length;
    var html='';
    for(var i=0;i<matches.length;i++){ var m=matches[i]; var meta=(m.date?String(m.date).slice(0,10):'')+(m.cats?'　·　'+m.cats:'');
      html+='<li><a href="'+esc(m.url)+'" data-idx="'+i+'" role="option"><p class="t">'+hl(m.title,q)+'</p>'+(meta?'<p class="m">'+esc(meta)+'</p>':'')+'</a></li>'; }
    resultsEl.innerHTML=html; mark();
  }
  function mark(){ var a=resultsEl.querySelectorAll('a[data-idx]'); for(var i=0;i<a.length;i++){ if(i===activeIdx){ a[i].setAttribute('aria-selected','true'); a[i].scrollIntoView({block:'nearest'}); } else a[i].removeAttribute('aria-selected'); } }

  var timer;
  input.addEventListener('input', function(){ var q=input.value; clearTimeout(timer); timer=setTimeout(function(){ render(search(q),q.trim()); },80); });
  input.addEventListener('keydown', function(e){
    if(e.key==='ArrowDown'){ e.preventDefault(); if(items.length){ activeIdx=(activeIdx+1)%items.length; mark(); } }
    else if(e.key==='ArrowUp'){ e.preventDefault(); if(items.length){ activeIdx=(activeIdx-1+items.length)%items.length; mark(); } }
    else if(e.key==='Enter'){ if(activeIdx>=0&&items[activeIdx]) window.location.href=items[activeIdx].url; }
    else if(e.key==='Escape'){ close(); }
  });
  modal.addEventListener('click', function(e){ if(e.target.closest('[data-cs-close]')){ close(); return; } if(!e.target.closest('[data-cs-stop]')) close(); });
  document.addEventListener('keydown', function(e){
    var mac=navigator.platform.toUpperCase().indexOf('MAC')>=0;
    if((mac?e.metaKey:e.ctrlKey)&&e.key.toLowerCase()==='k'){ e.preventDefault(); toggle(); }
    else if(e.key==='/'&&document.activeElement===document.body){ e.preventDefault(); open(); }
  });
  document.addEventListener('click', function(e){ if(e.target.closest('[data-cs-open]')){ e.preventDefault(); open(); } });
})();
</script>
