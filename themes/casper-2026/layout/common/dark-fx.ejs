<% if (theme.dark_fx && theme.dark_fx.enable) { %>
<canvas class="fx-rain" id="fx-rain" aria-hidden="true"></canvas>
<div class="fx-sweep" aria-hidden="true"></div>
<script>
(function(){
  if (!window.matchMedia) return;
  if (matchMedia('(prefers-reduced-motion: reduce)').matches) return; // 尊重減少動態
  var deskRain = matchMedia('(min-width: 1000px)'); // 雨僅桌機（顧行動裝置電量）
  function isDark(){ return document.documentElement.classList.contains('dark'); }

  /* ===== A：顏文字雨（單 canvas） ===== */
  var rain = (function(){
    var cv = document.getElementById('fx-rain'); if(!cv) return null;
    var ctx = cv.getContext('2d'), cols = [], raf = null, last = 0, on = false, rz;
    var G = [
      ['(・ω・)ノ','ヽ(・ω・)'],['ᕕ( ᐛ )ᕗ','ᕙ( ᐛ )ᕗ'],['┌(˘ω˘)┘','└(˘ω˘)┐'],
      ['(っ◔ω◔)っ','(づ◔ω◔)づ'],['(•◡•)/','\\(•◡•)'],['＼(^o^)／','／(^o^)＼'],
      ['(ﾉ´ヮ`)ﾉ','ヽ(´ヮ`ヽ)'],['o(>ω<)o','o(<ω>)o'],['( ´ ▽ ` )ﾉ','ヽ( ´ ▽ ` )'],
      '( ͡° ͜ʖ ͡°)','¯\\_(ツ)_/¯','</>','0x1A'
    ];
    function size(){
      var DPR = Math.min(devicePixelRatio || 1, 1.5);
      cv.width = innerWidth*DPR; cv.height = innerHeight*DPR;
      cv.style.width = innerWidth+'px'; cv.style.height = innerHeight+'px';
      ctx.setTransform(DPR,0,0,DPR,0,0);
      var n = Math.min(Math.floor(innerWidth/64), innerWidth<700 ? 14 : 22); cols = [];
      for(var i=0;i<n;i++) cols.push({ x:(i+.5)*(innerWidth/n), y:Math.random()*innerHeight, sp:34+Math.random()*46, g:G[(Math.random()*G.length)|0], ph:Math.random()*6 });
    }
    function tick(now){
      if(!on) return;
      var wait = 48 - (now - last);
      if(wait > 0){ raf = setTimeout(function(){ raf = requestAnimationFrame(tick); }, wait); return; } // 節流 ~20fps（不喚醒高刷新螢幕）
      var dt = (now-last)/1000; last = now;
      ctx.fillStyle = 'rgba(6,9,10,0.13)'; ctx.fillRect(0,0,innerWidth,innerHeight);
      ctx.font = '15px "JetBrains Mono",monospace'; ctx.textAlign = 'center';
      for(var i=0;i<cols.length;i++){ var c=cols[i]; c.y += c.sp*dt;
        if(c.y > innerHeight+24){ c.y = -24; c.g = G[(Math.random()*G.length)|0]; c.ph = Math.random()*6; }
        var x = c.x + Math.sin(now/520 + c.ph*3)*7;
        var rot = Math.sin(now/430 + c.ph*2)*0.18;
        var g = Array.isArray(c.g) ? c.g[(Math.floor(now/250 + c.ph)) & 1] : c.g;
        ctx.save(); ctx.translate(x, c.y); ctx.rotate(rot);
        ctx.fillStyle = 'rgba(125,247,181,.92)'; ctx.fillText(g,0,0);
        ctx.fillStyle = 'rgba(60,224,133,.42)'; ctx.fillText(g,0,-19);
        ctx.restore();
      }
      raf = requestAnimationFrame(tick);
    }
    addEventListener('resize', function(){ if(!on) return; clearTimeout(rz); rz = setTimeout(size,150); });
    return {
      start:function(){ if(on) return; on = true; size(); last = 0; raf = requestAnimationFrame(tick); },
      stop:function(){ if(!on) return; on = false; if(raf){ cancelAnimationFrame(raf); clearTimeout(raf); } ctx.clearRect(0,0,innerWidth,innerHeight); }
    };
  })();

  /* ===== B：七彩像素邊框跑光（卡片，動態插入 .edge-runner） ===== */
  var border = (function(){
    var timer = null, on = false;
    function run(){
      if(!on) return;
      var all = [].slice.call(document.querySelectorAll('.card'));
      var vis = all.filter(function(c){ var r=c.getBoundingClientRect(); return r.top<innerHeight && r.bottom>0; });
      var pool = vis.length ? vis : all, el = pool[(Math.random()*pool.length)|0];
      if(el && !el.querySelector('.edge-runner')){
        var rn = document.createElement('div'); rn.className = 'edge-runner'; el.appendChild(rn);
        var off = function(){ rn.remove(); rn.removeEventListener('animationend', off); };
        rn.addEventListener('animationend', off);
        setTimeout(function(){ if(rn.parentNode) rn.remove(); }, 6000); // 保險清除
      }
      timer = setTimeout(run, 4000 + Math.random()*6000);
    }
    return {
      start:function(){ if(on) return; on = true; timer = setTimeout(run, 1500); },
      stop:function(){ on = false; clearTimeout(timer); var rs = document.querySelectorAll('.edge-runner'); for(var i=0;i<rs.length;i++) rs[i].remove(); }
    };
  })();

  /* ===== 控制器：只在暗色 + 分頁可見時跑；sweep 由 CSS 控制 ===== */
  function sync(){
    var dark = isDark(), vis = !document.hidden;
    if(rain){ (dark && vis && deskRain.matches) ? rain.start() : rain.stop(); }
    (dark && vis) ? border.start() : border.stop();
  }
  new MutationObserver(sync).observe(document.documentElement, { attributes:true, attributeFilter:['class'] });
  document.addEventListener('visibilitychange', sync);
  if(deskRain.addEventListener) deskRain.addEventListener('change', sync);
  sync();
})();
</script>
<% } %>
