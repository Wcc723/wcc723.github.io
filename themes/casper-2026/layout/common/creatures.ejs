<% if (theme.creatures && theme.creatures.enable) { %>
<div id="creature-stage" aria-hidden="true"></div>
<script>
(function(){
  // 僅在「亮色 + 桌機 + 精準指標 + 未要求減少動態」時啟用
  if (!window.matchMedia) return;
  if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  if (!matchMedia('(min-width: 1000px) and (pointer: fine)').matches) return; // 對齊雙欄斷點
  var target = document.querySelector('.layout');
  var stage = document.getElementById('creature-stage');
  if (!target || !stage) return;

  function W(){ return window.innerWidth; }
  function H(){ return window.innerHeight; }
  var timers = [];
  function make(txt, color){
    var e = document.createElement('span'); e.className = 'creature';
    var sh = document.createElement('span'); sh.className = 'shadow';
    var f = document.createElement('span'); f.className = 'face'; f.textContent = txt; f.style.color = color;
    e.appendChild(sh); e.appendChild(f); stage.appendChild(e);
    return { el:e, face:f };
  }

  var defs = [
    { walk:['┌(・ω・)┘','└(・ω・)┐'],   flee:'(;・o・)', color:'#6f9fc4', baseDir: 1 }, // 偏男生 · 淺藍 · 順時針
    { walk:['┌(◕ᴗ◕)┘♡','└(◕ᴗ◕)┐♡'], flee:'(>o<)♡', color:'#cf7f9f', baseDir:-1 }  // 偏女生 · 粉紅 · 逆時針
  ];
  var STROLL = 14/1000, FLEE = 60/1000, OFF = 14;

  var bugs = defs.map(function(d){
    var c = make(d.walk[0], d.color);
    c.el.style.opacity = '0.9';
    c.p = 0; c.dir = d.baseDir; c.fleeing = false; c.calmAt = 0; c.def = d; c.step = 0;
    var t = setInterval(function(){
      c.step ^= 1;
      c.face.textContent = c.fleeing ? c.def.flee : c.def.walk[c.step];
    }, 480);
    timers.push(t);
    return c;
  });

  function box(){
    var r = target.getBoundingClientRect();
    var top = Math.max(r.top - OFF, 8);
    var bot = Math.min(r.bottom + OFF, H() - 8);
    return { x:r.left - OFF, y:top, w:(r.right + OFF) - (r.left - OFF), h:Math.max(60, bot - top) };
  }
  function ptAt(B, p){
    var per = 2*(B.w + B.h), d = (((p%1)+1)%1) * per;
    if(d < B.w) return { x:B.x + d, y:B.y };
    d -= B.w; if(d < B.h) return { x:B.x + B.w, y:B.y + d };
    d -= B.h; if(d < B.w) return { x:B.x + B.w - d, y:B.y + B.h };
    d -= B.w; return { x:B.x, y:B.y + B.h - d };
  }
  (function(){ var B = box(), per = 2*(B.w + B.h);
    bugs[0].p = (B.w + 0.30*B.h) / per;
    bugs[1].p = (2*B.w + B.h*(2 - 0.30)) / per;
  })();

  var last = performance.now(), nextHeartAt = 0, raf = null;

  function onMove(ev){
    if (document.documentElement.classList.contains('dark')) return; // 深色：不計算
    var B = box(), per = 2*(B.w + B.h), eps = 34/per;
    bugs.forEach(function(c){
      var here = ptAt(B, c.p);
      if(Math.hypot(here.x - ev.clientX, here.y - ev.clientY) < 140){
        if(!c.fleeing){ c.fleeing = true; c.face.textContent = c.def.flee; }
        var f = ptAt(B, c.p + eps), b = ptAt(B, c.p - eps);
        c.dir = (Math.hypot(f.x - ev.clientX, f.y - ev.clientY) >= Math.hypot(b.x - ev.clientX, b.y - ev.clientY)) ? 1 : -1;
        c.calmAt = performance.now() + 1700;
      }
    });
  }
  document.addEventListener('mousemove', onMove);

  function spawnHeart(x, y){
    var h = document.createElement('span'); h.className = 'heart';
    h.textContent = (Math.random() < 0.5) ? '♡' : '♥';
    h.style.left = (x + (Math.random()*16 - 8)) + 'px';
    h.style.top  = (y - 16) + 'px';
    stage.appendChild(h);
    h.addEventListener('animationend', function(){ h.remove(); });
    setTimeout(function(){ h.remove(); }, 3000); // 保險清除（h.remove 可重複呼叫）
  }

  function frame(now){
    // 深色模式：不動、不生愛心（避免隱藏時愛心 DOM 累積與多餘回流）
    if (document.documentElement.classList.contains('dark')) { last = now; raf = requestAnimationFrame(frame); return; }
    var dt = Math.min(now - last, 40); last = now;
    var B = box(), per = 2*(B.w + B.h);
    bugs.forEach(function(c, i){
      if(c.fleeing && now > c.calmAt){ c.fleeing = false; c.dir = c.def.baseDir; }
      var spd = c.fleeing ? FLEE : STROLL;
      c.p += c.dir * (spd * dt) / per;
      var pt = ptAt(B, c.p); c.px = pt.x; c.py = pt.y;
      var bob = Math.sin(now/230 + i) * 2.5;
      c.el.style.transform = 'translate('+pt.x+'px,'+pt.y+'px)';
      c.face.style.transform = 'translateY('+bob+'px)';
    });
    // 靠很近 → 低頻飄愛心（偶爾一兩顆）
    var dd = Math.hypot(bugs[0].px - bugs[1].px, bugs[0].py - bugs[1].py);
    if(dd < 88 && now > nextHeartAt){
      spawnHeart((bugs[0].px + bugs[1].px)/2, Math.min(bugs[0].py, bugs[1].py));
      nextHeartAt = now + 2200 + Math.random()*2800;
    }
    raf = requestAnimationFrame(frame);
  }

  // 分頁切到背景時暫停，省效能
  document.addEventListener('visibilitychange', function(){
    if(document.hidden){ if(raf){ cancelAnimationFrame(raf); raf = null; } }
    else if(!raf){ last = performance.now(); raf = requestAnimationFrame(frame); }
  });
  raf = requestAnimationFrame(frame);
})();
</script>
<% } %>
