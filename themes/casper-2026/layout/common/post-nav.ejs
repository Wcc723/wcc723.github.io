<% if (page.prev || page.next) { %>
<nav class="post-nav">
  <% if (page.next) { %>
    <a class="prev" href="<%- url_for(page.next.path) %>">
      <span class="lab">← 較舊一篇</span>
      <span class="ttl"><%= page.next.title %></span>
    </a>
  <% } else { %><span></span><% } %>
  <% if (page.prev) { %>
    <a class="next" href="<%- url_for(page.prev.path) %>">
      <span class="lab">較新一篇 →</span>
      <span class="ttl"><%= page.prev.title %></span>
    </a>
  <% } %>
</nav>
<% } %>
