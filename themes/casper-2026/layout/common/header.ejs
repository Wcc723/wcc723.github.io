<%
  var siteTitle = (config.title || '卡斯伯 Blog').split(' - ')[0];
  var vol = (new Date()).getFullYear() - (theme.issue_start_year || 2012);
%>
<div class="dateline"><div class="in">
  <span>第 <%= site.posts.length %> 篇 · 第 <%= vol %> 卷</span>
  <span class="c"><%= theme.tagline || '前端，沒有極限' %></span>
  <span><%= date(new Date(), 'YYYY 年 M 月 D 日') %> · 台北</span>
</div></div>

<header class="topbar"><nav class="nav">
  <span class="dots" aria-hidden="true"><i></i><i></i><i></i></span>
  <a class="brand" href="<%- url_for('/') %>"><% var av = theme.author && theme.author.avatar_img; %><span class="mk<%= av ? ' is-img' : '' %>"><% if (av) { %><img src="<%- url_for(av) %>" alt="<%= (theme.author && theme.author.alias) || config.author %>"><% } else { %><%= (theme.author && theme.author.avatar_char) || '卡' %><% } %></span><%= siteTitle %></a>
  <div class="menu">
    <% for (var key in theme.menu) { %>
      <a href="<%- url_for(theme.menu[key]) %>"<%- (key === '首頁' && is_home() && !page.prev) ? ' class="on"' : '' %>><%= key %></a>
    <% } %>
  </div>
  <span class="grow"></span>
  <button class="search-trig" type="button" data-cs-open>搜尋…<kbd>⌘K</kbd></button>
  <button class="iconbtn" type="button" id="theme-toggle" aria-label="切換深色模式" aria-pressed="false"><span aria-hidden="true">☾</span></button>
</nav></header>

<div class="wrap"><div class="cmdbar">
  <span class="q">ls -lt ./posts --since=2013<span class="cursor"></span></span>
  <span class="status">
    <span class="rec"></span> REC
    <span>·</span> node <span class="seal"><%= site.posts.length %></span>
    <span>·</span> uplink <span class="uplink"><i></i><i></i><i></i><i></i></span>
  </span>
</div></div>
