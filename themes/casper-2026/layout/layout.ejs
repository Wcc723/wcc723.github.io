<%- partial('common/head') %>
<body>
  <a class="skip-link" href="#main">跳到主要內容</a>
  <%
    // 閱讀內文頁(單篇文章、自訂頁面)關閉背景動畫特效,避免干擾閱讀;
    // 列表/首頁/彙整/標籤等 feed 頁維持特效。
    var readingView = is_post() || page.layout === 'page';
  %>
  <div class="atmos" aria-hidden="true">
    <div class="glow"></div><div class="grid"></div><div class="grain"></div><div class="scan"></div><div class="vig"></div>
  </div>
  <% if (!readingView) { %><%- partial('common/dark-fx') %><% } %>

  <%- partial('common/header') %>

  <div class="wrap">
    <div class="layout">
      <main id="main" tabindex="-1"><%- body %></main>
      <%- partial('common/sidebar') %>
    </div>
  </div>

  <%- partial('common/footer') %>
  <%- partial('search/casper') %>
  <% if (!readingView) { %><%- partial('common/creatures') %><% } %>
  <%- partial('common/scripts') %>
</body>
</html>
