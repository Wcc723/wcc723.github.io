<% if (theme.google_adsense && theme.google_adsense.enable && theme.google_adsense.client && theme.google_adsense.slot_inline) { %>
  <ins class="adsbygoogle"
       style="display:block"
       data-ad-format="fluid"
       data-ad-layout-key="<%= theme.google_adsense.layout_key %>"
       data-ad-client="<%= theme.google_adsense.client %>"
       data-ad-slot="<%= theme.google_adsense.slot_inline %>"></ins>
  <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
<% } %>
