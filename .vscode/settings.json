{
  "vsicons.presets.angular": false,
  "eslint.enable": false,

  // VS Code 內建 Markdown 貼圖(Cmd+V):把貼上的圖存到 r2-uploads/posts/<文章檔名>/,
  // 插入相對路徑(編輯器預覽可直接看到圖)。之後 `npm run images:upload` 會上傳 R2,
  // 並把文章裡的相對路徑改寫成 https://img.casper.tw/… 網址。
  "markdown.copyFiles.destination": {
    "/source/_posts/**": "${documentWorkspaceFolder}/r2-uploads/posts/${documentBaseName}/"
  }
}
