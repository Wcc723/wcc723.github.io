# Cloudflare R2 圖片上傳用(複製成 .env 並填值;.env 已在 .gitignore)
#
# 【可選】不想建這個 .env 也行:改用 wrangler OAuth 就好 ——
#   npm install && npx wrangler login
# 之後 images:upload / images:migrate 在「沒有 .env」時會自動改用 wrangler,免金鑰。
# 想要更快的並行上傳(尤其 695 檔遷移)才需要下面的 API 金鑰。
#
# 建立位置:Cloudflare Dashboard → R2 → Manage R2 API Tokens → Create(權限選 Object Read & Write)
# Secret 只顯示一次,當場存好。bucket 名稱與網域預設在 tools/r2.config.mjs,可不設。

R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=casper-blog-images

# 對外公開網域(R2 bucket → Settings → Custom Domains 綁定 img.casper.tw)。
# 物件 key 直接對應路徑:key posts/foo/bar.png → https://img.casper.tw/posts/foo/bar.png
R2_PUBLIC_BASE=https://img.casper.tw
